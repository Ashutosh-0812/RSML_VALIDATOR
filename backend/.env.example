# Environment Variables for Backend
# Copy this file to .env and fill in the values

# Database
MONGODB_URI=mongodb://localhost:27017/rsml_validator
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/rsml_validator

# Authentication
JWT_SECRET=your_very_secure_random_string_here

# Server
PORT=5000
NODE_ENV=development

# CORS
CORS_ORIGIN=*